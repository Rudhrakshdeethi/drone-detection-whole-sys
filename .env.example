# DRONEWATCH environment template — copy to `.env.local` and fill in.
#
#     cp .env.example .env.local     (PowerShell: Copy-Item .env.example .env.local)
#
# VITE_SSID — the WiFi SSID of the drone to detect + land. When a detection's
# SSID matches this value, the dashboard flags that drone on the camera + map
# and unlocks the LAND button for it. Leave blank for a generic demo.
VITE_SSID=DJI-Mavic-1A2B

# Optional — remote backend base URL. Leave unset to use the Vite dev proxy
# (which forwards /api to http://127.0.0.1:8080).
# VITE_API_BASE=http://raspberrypi.local:8080
