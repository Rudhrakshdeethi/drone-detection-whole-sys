{
  "name": "campusshield-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:all": "concurrently -k -n API,WEB -c green,cyan \"npm:backend\" \"npm:dev\"",
    "backend": "cd .. && python -m ml.runtime.dashboard --no-open --port 8080",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint"
  },
  "dependencies": {
    "leaflet": "1.9.4",
    "next": "15.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "1.9.16",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "concurrently": "9.1.2",
    "typescript": "5.7.3"
  }
}
